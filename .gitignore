# ==============================================================
# Terraform Global Ignore List
# ==============================================================

# Local object directory (Generated by 'terraform init')
.terraform/

# State files: These contain sensitive metadata about your infrastructure.
# NEVER commit these to a public repo.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs (Generated if Terraform crashes)
crash.log

# SENSITIVE DATA: Configuration files containing secrets, passwords, and tokens.
# Use 'terraform.tfvars.example' to share a template instead.
*.tfvars
*.tfvars.json

# Local overrides (Used for local testing, not meant for production)
override.tf
override.tf.json

# Dependency Lock File (Optional: some teams commit this, but for 
# personal portfolios it is often ignored to avoid version conflicts)
.terraform.lock.hcl

# SECURITY: Private keys and certificates
# These grant access to your OCI instances and API.
*.pem